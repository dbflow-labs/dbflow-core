{
  "key": "v10_sequential_approval",
  "name": "V1.0 Sequential Approval",
  "schema_version": "1.0",
  "description": "Sequential multi-candidate approval followed by a final single-user any approval.",
  "nodes": [
    {
      "key": "start",
      "type": "start",
      "name": "Start"
    },
    {
      "key": "manager_approval",
      "type": "approval",
      "name": "Manager Sequential Review",
      "config": {
        "approval_mode": "sequential",
        "assignees": {
          "type": "permission",
          "value": "v10_team"
        }
      }
    },
    {
      "key": "director_approval",
      "type": "approval",
      "name": "Director Final Review",
      "config": {
        "approval_mode": "any",
        "assignees": {
          "type": "user",
          "value": "3"
        }
      }
    },
    {
      "key": "end_approved",
      "type": "end",
      "name": "Approved",
      "config": {
        "status": "approved"
      }
    }
  ],
  "transitions": [
    {
      "from": "start",
      "to": "manager_approval",
      "is_default": true
    },
    {
      "from": "manager_approval",
      "to": "director_approval"
    },
    {
      "from": "director_approval",
      "to": "end_approved"
    }
  ]
}
